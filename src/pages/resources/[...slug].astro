---
import { getCollection, render } from 'astro:content';
import ResourceLayout from '../../layouts/ResourceLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('resources');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const canonical = `https://day-zero.com.au/resources/${entry.id}`;
---
<ResourceLayout data={entry.data} canonical={canonical}>
  <Content />
</ResourceLayout>
